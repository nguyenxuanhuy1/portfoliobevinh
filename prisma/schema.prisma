generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN

  @@map("users_role")
}

enum WorkStatus {
  READY
  NOT_READY

  @@map("work_status")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique @db.VarChar(255)
  name      String   @db.VarChar(255)
  avatar    String?  @db.VarChar(500)
  googleId  String?  @unique @map("google_id") @db.VarChar(255)
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("users")
}

model Project {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String   @db.Text
  image       String?  @db.VarChar(500)
  productLink String?  @map("product_link") @db.VarChar(500)
  githubLink  String?  @map("github_link") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@map("projects")
}

model AdminProfile {
  id         String     @id @default(uuid())
  name       String     @db.VarChar(255)
  position   String     @db.VarChar(255)
  bio        String     @db.Text
  skills     Json       @default("[]")
  workStatus WorkStatus @default(NOT_READY) @map("work_status")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @map("updated_at")

  @@map("admin_profiles")
}

model Skill {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  image     String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("skills")
}

model Experience {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String   @db.Text
  startDate   String   @db.VarChar(255)
  endDate     String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@map("experiences")
}

model Contact {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  link      String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("contacts")
}

model LearnTopic {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  data      Json     @map("data")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("learn_topics")
}

model Document {
  id            String   @id @default(uuid())
  subject       String   @map("subject") @db.VarChar(255)
  title         String   @map("title") @db.VarChar(255)
  description   String   @map("description") @db.Text
  level         Int      @default(0) @map("level")
  downloads     Int      @default(0) @map("downloads")
  views         Int      @default(0) @map("views")
  fileType      String   @map("file_type") @db.VarChar(50)
  fileSize      String   @map("file_size") @db.VarChar(50)
  tags          String[] @map("tags")
  mdDownloadUrl String   @map("md_download_url") @db.VarChar(500)
  downloadUrl   String[] @map("download_url")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("documents")
}
